# Backend Environment Variables — Template per Render.com
# Inserisci i valori reali nel dashboard di Render (Environment)

ENV=production
HOST=0.0.0.0
PORT=10000

# MongoDB Atlas
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=daniela_immobiliare

# CORS — in produzione puoi mettere i domini frontend separati da virgola
CORS_ORIGINS=*

# Cookie JWT in HTTPS
COOKIE_SECURE=true
COOKIE_SAMESITE=none

# Admin (cambia in produzione!)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMeInProduction!

# JWT — genera con: openssl rand -hex 32
JWT_SECRET=generaUnaStringaRandomDi64Caratteri0123456789abcdef0123456789abcdef

# Chat AI (Universal Key Emergent o tua chiave Anthropic/OpenAI)
EMERGENT_LLM_KEY=sk-emergent-...
