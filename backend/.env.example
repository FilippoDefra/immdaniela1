# Backend Environment Variables — Esempio
# Copia questo file in .env e compila i valori reali

# MongoDB
MONGO_URL="mongodb://localhost:27017"
DB_NAME="daniela_immobiliare"

# CORS — in produzione metti i tuoi domini reali separati da virgola
CORS_ORIGINS="*"

# Admin (cambia in produzione!)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMeInProduction!"

# JWT — genera con: openssl rand -hex 32
JWT_SECRET="generaUnaStringaRandomDi64Caratteri0123456789abcdef0123456789abcdef"

# Chat AI (Universal Key Emergent o tua chiave Anthropic/OpenAI)
EMERGENT_LLM_KEY="sk-emergent-..."
